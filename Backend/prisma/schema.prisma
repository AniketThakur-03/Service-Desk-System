generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  AGENT
  EMPLOYEE
}

enum AuditAction {
  USER_REGISTER
  USER_LOGIN
  LOGIN_FAILED
  ACCOUNT_LOCKED
  USER_LOGOUT
  TOKEN_REFRESHED
  ADMIN_LIST_USERS
  ROLE_CHANGED
  ROLE_DENIED
  TICKET_CREATED
  TICKET_UPDATED
  TICKET_ASSIGNED
  TICKET_STATUS_CHANGED
  INTERNAL_NOTE_BLOCKED
  PASSWORD_CHANGED
  SLA_BREACH_JOB_RUN
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketHistoryAction {
  CREATED
  STATUS_CHANGED
  ASSIGNED
  UPDATED
  SLA_BREACHED
  COMMENT_ADDED
  REOPENED
  RESOLUTION_ADDED
  LINKED_ASSET
}

enum AssetStatus {
  IN_STOCK
  ASSIGNED
  IN_REPAIR
  RETIRED
}

model User {
  id                  String             @id @default(uuid())
  email               String             @unique
  passwordHash        String
  role                Role               @default(EMPLOYEE)
  failedLoginAttempts Int                @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  passwordChangedAt   DateTime           @default(now())
  createdAt           DateTime           @default(now())
  requesterTickets    Ticket[]           @relation("RequesterTickets")
  assigneeTickets     Ticket[]           @relation("AssigneeTickets")
  comments            TicketComment[]
  refreshTokens       RefreshToken[]
  securityEvents      SecurityEvent[]
  notifications       Notification[]
  assignedAssets      Asset[]            @relation("AssignedAssets")
  articles            KnowledgeArticle[] @relation("ArticleAuthor")
}

model AuditLog {
  id         String      @id @default(uuid())
  action     AuditAction
  actorId    String?
  actorEmail String?
  targetType String?
  targetId   String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  @@index([createdAt])
}

model Ticket {
  id                String             @id @default(uuid())
  title             String
  description       String
  category          String             @default("General Support")
  status            TicketStatus       @default(OPEN)
  priority          TicketPriority     @default(MEDIUM)
  comments          TicketComment[]
  history           TicketHistory[]
  resolutionSummary String?

  requesterId String
  requester   User   @relation("RequesterTickets", fields: [requesterId], references: [id])

  assigneeId String?
  assignee   User?   @relation("AssigneeTickets", fields: [assigneeId], references: [id])

  assetId String?
  asset   Asset? @relation(fields: [assetId], references: [id], onDelete: SetNull)

  slaDueAt    DateTime?
  slaBreached Boolean   @default(false)
  resolvedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([requesterId])
  @@index([assigneeId])
  @@index([assetId])
}

model TicketComment {
  id String @id @default(uuid())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  body       String
  isInternal Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([authorId])
}

model TicketHistory {
  id         String              @id @default(cuid())
  ticketId   String
  ticket     Ticket              @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  action     TicketHistoryAction
  field      String?
  oldValue   String?
  newValue   String?
  actorId    String?
  actorEmail String?
  createdAt  DateTime            @default(now())

  @@index([ticketId])
}

model RefreshToken {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model SecurityEvent {
  id        String   @id @default(uuid())
  category  String
  severity  String
  eventType String
  message   String
  sourceIp  String?
  requestId String?
  userId    String?
  userEmail String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([severity])
  @@index([category])
  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String   @default("INFO")
  link      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Asset {
  id             String      @id @default(uuid())
  name           String
  assetTag       String      @unique
  type           String
  serialNumber   String?
  location       String?
  status         AssetStatus @default(IN_STOCK)
  purchaseDate   DateTime?
  warrantyEndsAt DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  assignedUserId String?
  assignedUser   User?   @relation("AssignedAssets", fields: [assignedUserId], references: [id], onDelete: SetNull)

  tickets Ticket[]

  @@index([status])
  @@index([assignedUserId])
}

model KnowledgeArticle {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  summary     String
  content     String
  category    String   @default("General")
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId String?
  author   User? @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([isPublished])
}
